<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>We Care Foundation | Empowering Communities</title>
  <!-- Font Awesome 6 (Free Icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts: Poppins & Inter blend -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #fefcf5;
      color: #1e2a3e;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    h1, h2, h3, .logo, .nav-links a, .btn, .donate-btn-nav {
      font-family: 'Poppins', 'Inter', sans-serif;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 28px;
    }

    /* header & navigation */
    header {
      background: white;
      box-shadow: 0 8px 20px rgba(0,0,0,0.03), 0 2px 6px rgba(0,0,0,0.05);
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(0px);
      background: rgba(255,255,245,0.98);
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo i {
      font-size: 2rem;
      color: #e65c2e;
      background: #ffede5;
      padding: 8px;
      border-radius: 20px;
    }
    .logo span {
      font-weight: 800;
      font-size: 1.55rem;
      letter-spacing: -0.3px;
      color: #1e3a2f;
    }
    .logo span small {
      font-size: 0.8rem;
      font-weight: 500;
      display: block;
      letter-spacing: normal;
      color: #e65c2e;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 600;
      color: #2c3e2f;
      transition: 0.2s;
      font-size: 1rem;
    }
    .nav-links a:hover {
      color: #e65c2e;
    }
    .donate-btn-nav {
      background: #e65c2e;
      color: white !important;
      padding: 8px 20px;
      border-radius: 40px;
      transition: 0.2s;
      box-shadow: 0 4px 8px rgba(230,92,46,0.2);
    }
    .donate-btn-nav:hover {
      background: #c2451e;
      transform: translateY(-2px);
      color: white;
    }

    /* hero section */
    .hero {
      padding: 4rem 0 3rem;
      background: linear-gradient(135deg, #fff6ed 0%, #fff9f0 100%);
      border-bottom: 1px solid #ffead9;
    }
    .hero-grid {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
    .hero-content {
      flex: 1.2;
    }
    .hero-badge {
      background: #ffede3;
      display: inline-block;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      color: #e65c2e;
      margin-bottom: 1.2rem;
    }
    .hero-content h1 {
      font-size: 3rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1.2rem;
      color: #1e3a2f;
    }
    .hero-content h1 span {
      color: #e65c2e;
      border-bottom: 3px solid #f8c4a0;
    }
    .hero-description {
      font-size: 1.1rem;
      color: #3a4f41;
      margin-bottom: 2rem;
      max-width: 90%;
    }
    .btn-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .btn-primary, .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      border-radius: 60px;
      font-weight: 700;
      text-decoration: none;
      transition: 0.25s;
      font-size: 1rem;
    }
    .btn-primary {
      background: #e65c2e;
      color: white;
      border: none;
      box-shadow: 0 8px 14px rgba(230,92,46,0.25);
    }
    .btn-primary:hover {
      background: #c2451e;
      transform: translateY(-3px);
      box-shadow: 0 12px 20px rgba(230,92,46,0.3);
    }
    .btn-outline {
      background: transparent;
      border: 2px solid #e65c2e;
      color: #e65c2e;
    }
    .btn-outline:hover {
      background: #e65c2e;
      color: white;
      transform: translateY(-2px);
    }
    .whatsapp-chip {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: white;
      padding: 10px 24px;
      border-radius: 100px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.02);
      border: 1px solid #e2e8dd;
      font-weight: 600;
    }
    .whatsapp-chip i {
      font-size: 1.5rem;
      color: #25D366;
    }
    .whatsapp-chip a {
      text-decoration: none;
      color: #1e3a2f;
      font-weight: 700;
      transition: 0.2s;
    }
    .whatsapp-chip a:hover {
      color: #25D366;
    }
    .hero-img {
      flex: 0.9;
      text-align: center;
    }
    .hero-img i {
      font-size: 14rem;
      color: #fad5bd;
      filter: drop-shadow(0 10px 15px rgba(0,0,0,0.05));
    }

    /* sections general */
    section {
      padding: 5rem 0;
    }
    .section-title {
      text-align: center;
      font-size: 2.3rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: #1e3a2f;
    }
    .section-sub {
      text-align: center;
      max-width: 680px;
      margin: 0 auto 3rem auto;
      color: #5b6e5e;
    }

    /* about */
    .about-grid {
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .about-text {
      flex: 1;
    }
    .about-text p {
      margin-bottom: 1.2rem;
      font-size: 1rem;
      color: #2d3e31;
    }
    .stats {
      display: flex;
      gap: 2rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }
    .stat-item {
      background: #fff4ed;
      padding: 0.8rem 1.8rem;
      border-radius: 50px;
      text-align: center;
    }
    .stat-number {
      font-weight: 800;
      font-size: 1.8rem;
      color: #e65c2e;
    }
    .about-image {
      flex: 1;
      background: #fae9df;
      border-radius: 50px;
      padding: 2rem;
      text-align: center;
    }
    .about-image i {
      font-size: 8rem;
      color: #eab194;
    }

    /* programs cards */
    .programs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 1.5rem;
    }
    .program-card {
      background: white;
      border-radius: 32px;
      padding: 2rem 1.5rem;
      box-shadow: 0 15px 35px rgba(0,0,0,0.03);
      transition: all 0.3s ease;
      border: 1px solid #f3ede5;
      text-align: center;
    }
    .program-card:hover {
      transform: translateY(-8px);
      border-color: #ffd8c4;
      box-shadow: 0 25px 40px rgba(0,0,0,0.08);
    }
    .program-icon {
      font-size: 3rem;
      background: #fff3eb;
      width: 80px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 40px;
      margin: 0 auto 1.2rem;
      color: #e65c2e;
    }
    .program-card h3 {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .program-card p {
      color: #5a6a5e;
      margin-bottom: 1.2rem;
    }
    .donate-mini-btn {
      background: none;
      border: 1px solid #e65c2e;
      padding: 6px 18px;
      border-radius: 50px;
      font-weight: 600;
      color: #e65c2e;
      cursor: pointer;
      transition: 0.2s;
    }
    .donate-mini-btn:hover {
      background: #e65c2e;
      color: white;
    }

    /* contact section with whatsapp */
    .contact-wrap {
      background: #fef8f2;
      border-radius: 56px;
      padding: 3rem 2rem;
      margin-top: 1rem;
    }
    .contact-flex {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
    .contact-info {
      flex: 1;
    }
    .contact-info h3 {
      font-size: 1.7rem;
      margin-bottom: 1rem;
    }
    .contact-detail {
      display: flex;
      align-items: center;
      gap: 20px;
      margin: 1.5rem 0;
      background: white;
      padding: 1rem 1.8rem;
      border-radius: 60px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
      border: 1px solid #ffe5d6;
    }
    .contact-detail i {
      font-size: 2rem;
    }
    .contact-detail .whatsapp-number {
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .contact-detail a {
      text-decoration: none;
      color: #1e3a2f;
      font-weight: 700;
    }
    .contact-detail a:hover {
      color: #25D366;
    }
    .contact-detail span {
      margin-left: 8px;
      font-weight: 500;
    }
    .contact-cta {
      text-align: center;
      flex: 0.8;
      background: white;
      padding: 2rem;
      border-radius: 48px;
    }
    .contact-cta .btn-primary {
      margin-top: 1rem;
    }

    /* donation modal */
    .donation-modal {
      display: none;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background-color: rgba(0,0,0,0.6);
      backdrop-filter: blur(6px);
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }
    .modal-content {
      background: #fffef7;
      max-width: 480px;
      width: 90%;
      border-radius: 48px;
      padding: 2rem 1.8rem;
      position: relative;
      box-shadow: 0 35px 60px rgba(0,0,0,0.2);
      animation: fadeSlideUp 0.2s ease;
    }
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(30px);}
      to { opacity: 1; transform: translateY(0);}
    }
    .modal-content h3 {
      font-size: 1.8rem;
      margin-bottom: 0.5rem;
      color: #1e3a2f;
    }
    .modal-close {
      position: absolute;
      right: 1.5rem;
      top: 1.5rem;
      font-size: 1.5rem;
      cursor: pointer;
      color: #8b9a8b;
    }
    .form-group {
      margin-bottom: 1.2rem;
    }
    .form-group label {
      font-weight: 600;
      display: block;
      margin-bottom: 6px;
    }
    .form-group input, .form-group select {
      width: 100%;
      padding: 12px 16px;
      border-radius: 40px;
      border: 1px solid #e2dacf;
      font-family: inherit;
    }
    .donate-submit {
      background: #e65c2e;
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 60px;
      font-weight: 700;
      color: white;
      font-size: 1rem;
      cursor: pointer;
      transition: 0.2s;
    }
    .donate-submit:hover {
      background: #bf4a21;
    }
    footer {
      background: #1e2c23;
      color: #cfdfcf;
      text-align: center;
      padding: 2rem;
      font-size: 0.85rem;
    }
    @media (max-width: 800px) {
      .hero-content h1 { font-size: 2.2rem; }
      .navbar { flex-direction: column; }
      .nav-links { justify-content: center; gap: 1rem; }
      .hero-img i { font-size: 8rem; }
      .contact-detail { flex-wrap: wrap; justify-content: center; text-align: center; }
    }
    button {
      background: none;
      border: none;
      cursor: pointer;
    }
  </style>
</head>
<body>

<header>
  <div class="container">
    <div class="navbar">
      <div class="logo">
        <i class="fas fa-hand-holding-heart"></i>
        <span>WE CARE <small>Foundation</small></span>
      </div>
      <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#programs">Programs</a>
        <a href="#contact">Connect</a>
        <button class="donate-btn-nav donate-trigger" id="navDonateBtn"><i class="fas fa-heart"></i> Donate</button>
      </div>
    </div>
  </div>
</header>

<main>
  <!-- Hero Section -->
  <section id="home" class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <div class="hero-badge"><i class="fas fa-seedling"></i>  Trust since 2015</div>
        <h1>Spreading Hope, <span>One Heart</span> at a Time</h1>
        <p class="hero-description">We Care Foundation is dedicated to empowering underprivileged communities through education, healthcare, and nutrition. Together we transform lives.</p>
        <div class="btn-group">
          <button class="btn-primary donate-trigger"><i class="fas fa-hand-holding-usd"></i> Donate Now</button>
          <a href="https://wa.me/919595944888?text=Hello%20We%20Care%20Foundation%2C%20I%20want%20to%20support%20your%20mission" target="_blank" class="btn-outline"><i class="fab fa-whatsapp"></i> WhatsApp Us</a>
        </div>
        <div class="whatsapp-chip">
          <i class="fab fa-whatsapp"></i>
          <span>Connect on WhatsApp : </span>
          <a href="https://wa.me/919595944888" target="_blank">+91 95959 44888</a>
        </div>
      </div>
      <div class="hero-img">
        <i class="fas fa-hands-helping"></i>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about">
    <div class="container">
      <h2 class="section-title">Who We Are</h2>
      <div class="about-grid">
        <div class="about-text">
          <p><strong>We Care Foundation</strong> is a registered non-profit trust working relentlessly for the upliftment of marginalized children, families, and elderly. Our mission is to create a world where no one is deprived of basic necessities, education, and dignity.</p>
          <p>With grassroots projects across urban & rural regions, we have impacted thousands of lives. Every contribution fuels our journey toward a compassionate society.</p>
          <div class="stats">
            <div class="stat-item"><span class="stat-number">25+</span><br>Projects</div>
            <div class="stat-item"><span class="stat-number">12k+</span><br>Lives Touched</div>
            <div class="stat-item"><span class="stat-number">150+</span><br>Volunteers</div>
          </div>
        </div>
        <div class="about-image">
          <i class="fas fa-children"></i>
          <p style="margin-top: 1rem; font-weight:500;">Building brighter tomorrows</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs Section -->
  <section id="programs" style="background: #fefaf5;">
    <div class="container">
      <h2 class="section-title">Our Initiatives</h2>
      <p class="section-sub">From education to emergency relief, we focus on sustainable impact.</p>
      <div class="programs-grid">
        <div class="program-card">
          <div class="program-icon"><i class="fas fa-book-open"></i></div>
          <h3>Education for All</h3>
          <p>Providing learning resources, scholarships, and digital access to children in need.</p>
          <button class="donate-mini-btn donate-trigger">Support this cause</button>
        </div>
        <div class="program-card">
          <div class="program-icon"><i class="fas fa-heartbeat"></i></div>
          <h3>Health & Nutrition</h3>
          <p>Medical camps, nutritious meals, and mental wellness support for vulnerable families.</p>
          <button class="donate-mini-btn donate-trigger">Donate for Health</button>
        </div>
        <div class="program-card">
          <div class="program-icon"><i class="fas fa-hand-holding-water"></i></div>
          <h3>Livelihood & Women Empowerment</h3>
          <p>Skill development, micro-enterprise support, and creating sustainable income sources.</p>
          <button class="donate-mini-btn donate-trigger">Empower Today</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact + WhatsApp Section (explicit logo & number) -->
  <section id="contact">
    <div class="container">
      <div class="contact-wrap">
        <div class="contact-flex">
          <div class="contact-info">
            <h3><i class="fas fa-phone-alt"></i> Reach out to us</h3>
            <p>Your support and queries matter — let's make a difference together.</p>
            <div class="contact-detail">
              <i class="fab fa-whatsapp" style="color:#25D366;"></i>
              <div>
                <div class="whatsapp-number">+91 95959 44888</div>
                <a href="https://wa.me/919595944888" target="_blank">Chat with us on WhatsApp <i class="fas fa-external-link-alt"></i></a>
              </div>
            </div>
            <div class="contact-detail">
              <i class="fas fa-envelope"></i>
              <span>care@wecarefoundation.org</span>
            </div>
            <div class="contact-detail">
              <i class="fas fa-map-marker-alt"></i>
              <span>Mumbai | Delhi | Bangalore (HQ: New Delhi, India)</span>
            </div>
          </div>
          <div class="contact-cta">
            <i class="fas fa-hands-clapping" style="font-size: 2.5rem; color:#e65c2e;"></i>
            <h3 style="margin: 10px 0;">Join the movement</h3>
            <p>Every rupee you donate brings smiles & transforms futures.</p>
            <button class="btn-primary donate-trigger" style="padding: 12px 28px;"><i class="fas fa-gift"></i> Donate Now</button>
            <p style="margin-top: 18px; font-size:0.8rem;"><i class="fab fa-whatsapp"></i> Scan/Click the WhatsApp number for direct chat</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <div class="container">
    <p><i class="fas fa-heart" style="color: #e65c2e;"></i> We Care Foundation — A registered charitable trust (Reg. No. 1289/2015) </p>
    <p style="margin-top: 0.6rem;">© 2025 | Empowering lives with compassion | Donations eligible for 80G tax benefits</p>
    <p style="margin-top: 0.6rem; font-size:0.8rem;"><i class="fab fa-whatsapp"></i> WhatsApp Helpline: +91 9595944888</p>
  </div>
</footer>

<!-- Donation Modal (demo) -->
<div id="donationModal" class="donation-modal">
  <div class="modal-content">
    <span class="modal-close" id="closeModalBtn">&times;</span>
    <h3><i class="fas fa-donate"></i> Make a Donation</h3>
    <p>Your generosity fuels real change. Fill the form (demo mode)</p>
    <form id="donateForm">
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" id="donorName" placeholder="e.g., Sunita Sharma" required>
      </div>
      <div class="form-group">
        <label>Email address</label>
        <input type="email" id="donorEmail" placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label>Donation Amount (₹)</label>
        <select id="donationAmount">
          <option value="500">₹500 – Provides school kit for a child</option>
          <option value="1000" selected>₹1,000 – Monthly nutrition support</option>
          <option value="2500">₹2,500 – Educational scholarship</option>
          <option value="5000">₹5,000 – Medical camp sponsorship</option>
          <option value="other">Other amount</option>
        </select>
      </div>
      <div class="form-group" id="customAmountDiv" style="display:none;">
        <label>Custom Amount (₹)</label>
        <input type="number" id="customAmount" placeholder="Enter amount" min="50">
      </div>
      <button type="submit" class="donate-submit"><i class="fas fa-check-circle"></i> Proceed (Demo)</button>
      <p style="font-size: 0.7rem; margin-top: 1rem; text-align: center;">⚠️ Demo version — your support matters! Thank you for caring.</p>
    </form>
  </div>
</div>

<script>
  // DOM elements
  const modal = document.getElementById('donationModal');
  const closeModalBtn = document.getElementById('closeModalBtn');
  const donateTriggers = document.querySelectorAll('.donate-trigger');
  const amountSelect = document.getElementById('donationAmount');
  const customAmountDiv = document.getElementById('customAmountDiv');
  const donateForm = document.getElementById('donateForm');

  // open modal
  function openModal() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  // attach to all donate buttons
  donateTriggers.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });

  // close via X or background click
  closeModalBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // show custom amount field if other selected
  amountSelect.addEventListener('change', function() {
    if (this.value === 'other') {
      customAmountDiv.style.display = 'block';
    } else {
      customAmountDiv.style.display = 'none';
    }
  });

  // Donation form submit (demo interaction)
  donateForm.addEventListener('submit', function(e) {
    e.preventDefault();
    let donorName = document.getElementById('donorName').value.trim();
    let amount = amountSelect.value;
    let customAmt = document.getElementById('customAmount').value;
    let finalAmount = 0;

    if (amount === 'other') {
      if (customAmt && parseInt(customAmt) > 0) {
        finalAmount = parseInt(customAmt);
      } else {
        alert('Please enter a valid custom donation amount.');
        return;
      }
    } else {
      finalAmount = parseInt(amount);
    }

    if (donorName === '') {
      alert('Please enter your name to continue.');
      return;
    }

    // Demo success message
    alert(`✨ Thank you ${donorName} for your generous contribution of ₹${finalAmount}! ✨\n\nWe Care Foundation appreciates your compassion. (This is a demo, but your intent truly matters. Official payment gateway coming soon.)`);
    
    // reset form and close modal
    donateForm.reset();
    customAmountDiv.style.display = 'none';
    document.getElementById('donorName').value = '';
    document.getElementById('donorEmail').value = '';
    closeModal();
  });

  // close modal when escape pressed
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeModal();
    }
  });
  
  // optional: remove overflow on close
  window.addEventListener('load', () => {
    // set initial select
    amountSelect.dispatchEvent(new Event('change'));
  });
</script>
